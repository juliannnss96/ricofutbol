{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
{{ 'component-ugc-showcase.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="ugc-showcase color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="ugc-showcase__inner page-width">
    <div class="ugc-showcase__header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if section.settings.title != blank -%}
        <h2 class="ugc-showcase__title {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="ugc-showcase__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <slider-component class="ugc-showcase__slider{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <ul
          id="Slider-{{ section.id }}"
          class="ugc-showcase__list slider slider--everywhere grid grid--peek"
          role="list"
        >
          {%- for block in section.blocks -%}
            {%- liquid
              assign video = block.settings.video
              assign poster = block.settings.thumbnail | default: video.preview_image
              assign aspect_ratio = poster.aspect_ratio | default: 0.5625
              assign ratio_percent = 1 | divided_by: aspect_ratio | times: 100
            -%}
            <li
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="ugc-showcase__item slider__slide{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {{ block.shopify_attributes }}
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
            >
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="ugc-showcase__link">
              {%- endif -%}

              {%- if video != null -%}
                <deferred-media
                  class="ugc-showcase__media media media--transparent"
                  data-media-id="{{ video.id }}"
                  style="--ratio-percent: {{ ratio_percent }}%;"
                >
                  <button
                    id="Deferred-Poster-{{ section.id }}-{{ forloop.index }}"
                    class="ugc-showcase__poster deferred-media__poster"
                    type="button"
                    aria-label="{{ 'sections.video.load_video' | t: description: block.settings.caption | escape }}"
                  >
                    {%- if poster != null -%}
                      {{
                        poster
                        | image_url: width: 800
                        | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 220px, 45vw', widths: '220, 330, 440, 660'
                      }}
                    {%- else -%}
                      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                    {%- endif -%}
                    <span class="ugc-showcase__play-button deferred-media__poster-button motion-reduce">
                      <span class="svg-wrapper">
                        {{- 'icon-play.svg' | inline_asset_content -}}
                      </span>
                    </span>
                  </button>
                  <template>
                    {{
                      video
                      | video_tag:
                        image_size: '800x',
                        autoplay: true,
                        loop: false,
                        controls: true,
                        muted: false
                    }}
                  </template>
                </deferred-media>
              {%- else -%}
                <div class="ugc-showcase__media ugc-showcase__media--placeholder media media--transparent" style="--ratio-percent: 177.78%;">
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                </div>
              {%- endif -%}

              {%- if block.settings.caption != blank -%}
                <p class="ugc-showcase__caption">{{ block.settings.caption }}</p>
              {%- endif -%}

              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
        <div class="slider-buttons">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </button>
          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ section.blocks.size }}</span>
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </button>
        </div>
      </slider-component>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "UGC showcase",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Worn by pros. Loved by everyone."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "10,000+ 5 Star Reviews"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Tamaño del título",
      "options": [
        {
          "value": "h2",
          "label": "Pequeño"
        },
        {
          "value": "h1",
          "label": "Mediano"
        },
        {
          "value": "h0",
          "label": "Grande"
        }
      ],
      "default": "h1"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.all.padding.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.all.padding.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Video",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Miniatura (opcional)",
          "info": "Se usa como portada antes de reproducir. Si no se define, se usa la del video."
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Texto (opcional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace (opcional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC showcase",
      "blocks": [
        {
          "type": "video_card"
        },
        {
          "type": "video_card"
        },
        {
          "type": "video_card"
        },
        {
          "type": "video_card"
        },
        {
          "type": "video_card"
        }
      ]
    }
  ]
}
{% endschema %}
