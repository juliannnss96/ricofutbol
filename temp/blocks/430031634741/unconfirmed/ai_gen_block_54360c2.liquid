{% doc %}
  @prompt
    encabezado
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-header-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    border-bottom: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    position: {{ block.settings.position }};
    top: 0;
    left: 0;
    z-index: 1000;
    box-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
  }

  .ai-header-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .ai-header-logo-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: {{ block.settings.text_color }};
  }

  .ai-header-logo-image-{{ ai_gen_id }} {
    max-width: {{ block.settings.logo_width }}px;
    height: auto;
    display: block;
  }

  .ai-header-logo-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.logo_text_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-header-nav-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.nav_spacing }}px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-header-nav-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.nav_font_size }}px;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .ai-header-nav-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-header-actions-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ai-header-icon-button-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.text_color }};
    transition: color 0.3s ease;
  }

  .ai-header-icon-button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-header-icon-button-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
  }

  .ai-header-menu-toggle-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-header-nav-{{ ai_gen_id }} {
      display: none;
    }

    .ai-header-menu-toggle-{{ ai_gen_id }} {
      display: flex;
    }

    .ai-header-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }

    .ai-header-logo-image-{{ ai_gen_id }} {
      max-width: {{ block.settings.logo_width | times: 0.8 }}px;
    }

    .ai-header-logo-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.logo_text_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<header-component-{{ ai_gen_id }} class="ai-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-header-container-{{ ai_gen_id }}">
    <a href="/" class="ai-header-logo-{{ ai_gen_id }}">
      {% if block.settings.logo %}
        <img
          src="{{ block.settings.logo | image_url: width: 400 }}"
          alt="{{ shop.name }}"
          class="ai-header-logo-image-{{ ai_gen_id }}"
          width="{{ block.settings.logo.width }}"
          height="{{ block.settings.logo.height }}"
          loading="eager"
        >
      {% else %}
        <h1 class="ai-header-logo-text-{{ ai_gen_id }}">{{ block.settings.logo_text }}</h1>
      {% endif %}
    </a>

    {% if block.settings.show_navigation %}
      <nav>
        <ul class="ai-header-nav-{{ ai_gen_id }}">
          {% if block.settings.nav_link_1_text != blank %}
            <li>
              <a href="{{ block.settings.nav_link_1_url }}" class="ai-header-nav-link-{{ ai_gen_id }}">
                {{ block.settings.nav_link_1_text }}
              </a>
            </li>
          {% endif %}
          {% if block.settings.nav_link_2_text != blank %}
            <li>
              <a href="{{ block.settings.nav_link_2_url }}" class="ai-header-nav-link-{{ ai_gen_id }}">
                {{ block.settings.nav_link_2_text }}
              </a>
            </li>
          {% endif %}
          {% if block.settings.nav_link_3_text != blank %}
            <li>
              <a href="{{ block.settings.nav_link_3_url }}" class="ai-header-nav-link-{{ ai_gen_id }}">
                {{ block.settings.nav_link_3_text }}
              </a>
            </li>
          {% endif %}
          {% if block.settings.nav_link_4_text != blank %}
            <li>
              <a href="{{ block.settings.nav_link_4_url }}" class="ai-header-nav-link-{{ ai_gen_id }}">
                {{ block.settings.nav_link_4_text }}
              </a>
            </li>
          {% endif %}
        </ul>
      </nav>
    {% endif %}

    <div class="ai-header-actions-{{ ai_gen_id }}">
      {% if block.settings.show_search %}
        <button
          class="ai-header-icon-button-{{ ai_gen_id }}"
          aria-label="Buscar"
          type="button"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
      {% endif %}

      {% if block.settings.show_account %}
        <a
          href="/account"
          class="ai-header-icon-button-{{ ai_gen_id }}"
          aria-label="Cuenta"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </a>
      {% endif %}

      {% if block.settings.show_cart %}
        <a
          href="/cart"
          class="ai-header-icon-button-{{ ai_gen_id }}"
          aria-label="Carrito"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </a>
      {% endif %}

      <button
        class="ai-header-icon-button-{{ ai_gen_id }} ai-header-menu-toggle-{{ ai_gen_id }}"
        aria-label="Menú"
        type="button"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</header-component-{{ ai_gen_id }}>

<script>
  (function() {
    class HeaderComponent{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        const menuToggle = this.querySelector('.ai-header-menu-toggle-{{ ai_gen_id }}');
        if (menuToggle) {
          menuToggle.addEventListener('click', () => {
            console.log('Menu toggle clicked');
          });
        }
      }
    }

    customElements.define('header-component-{{ ai_gen_id }}', HeaderComponent{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Encabezado",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Imagen del logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Ancho del logo",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Texto del logo",
      "default": "Mi tienda"
    },
    {
      "type": "range",
      "id": "logo_text_size",
      "label": "Tamaño del texto",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Navegación"
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Mostrar navegación",
      "default": true
    },
    {
      "type": "text",
      "id": "nav_link_1_text",
      "label": "Enlace 1 - Texto",
      "default": "Inicio"
    },
    {
      "type": "url",
      "id": "nav_link_1_url",
      "label": "Enlace 1 - URL"
    },
    {
      "type": "text",
      "id": "nav_link_2_text",
      "label": "Enlace 2 - Texto",
      "default": "Productos"
    },
    {
      "type": "url",
      "id": "nav_link_2_url",
      "label": "Enlace 2 - URL"
    },
    {
      "type": "text",
      "id": "nav_link_3_text",
      "label": "Enlace 3 - Texto",
      "default": "Colecciones"
    },
    {
      "type": "url",
      "id": "nav_link_3_url",
      "label": "Enlace 3 - URL"
    },
    {
      "type": "text",
      "id": "nav_link_4_text",
      "label": "Enlace 4 - Texto",
      "default": "Contacto"
    },
    {
      "type": "url",
      "id": "nav_link_4_url",
      "label": "Enlace 4 - URL"
    },
    {
      "type": "range",
      "id": "nav_font_size",
      "label": "Tamaño de fuente",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "nav_spacing",
      "label": "Espaciado entre enlaces",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Acciones"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Mostrar búsqueda",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Mostrar cuenta",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "Mostrar carrito",
      "default": true
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Tamaño de iconos",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Estilo"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de texto",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Color al pasar el cursor",
      "default": "#334fb4"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Espaciado vertical",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Espaciado horizontal",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Ancho del contenedor",
      "min": 1000,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "select",
      "id": "position",
      "label": "Posición",
      "options": [
        {
          "value": "relative",
          "label": "Normal"
        },
        {
          "value": "sticky",
          "label": "Fijo al desplazar"
        }
      ],
      "default": "sticky"
    },
    {
      "type": "range",
      "id": "border_thickness",
      "label": "Grosor del borde",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Color del borde",
      "default": "#e5e5e5"
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "label": "Opacidad de sombra",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 5
    }
  ],
  "presets": [
    {
      "name": "Encabezado"
    }
  ]
}
{% endschema %}
